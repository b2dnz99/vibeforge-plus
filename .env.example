# VibeForge+ environment configuration.
# Copy this file to `.env` (gitignored) and fill in the values for your install.
#
# All values below are required for `docker compose up` to start cleanly.
# Comments mark which values you MUST change vs which can keep their defaults.
#
# ─── Hostname ────────────────────────────────────────────────────────────────
# The canonical hostname operators + agents will use to reach this install.
# Examples:
#   public DNS:        VIBEFORGE_HOSTNAME=vibeforge.example.com
#   LAN-only / mDNS:   VIBEFORGE_HOSTNAME=vibeforge.local
#   single-machine:    VIBEFORGE_HOSTNAME=localhost
# Caddy mints the cert against this hostname (internal CA mode by default).
# Forgejo + Vaultwarden also derive their domain from this var if those
# services are enabled.
VIBEFORGE_HOSTNAME=localhost

# ─── App secrets ─────────────────────────────────────────────────────────────
# CHANGE THESE before exposing the install on any network beyond your laptop.
# SECRET_KEY signs session cookies. Rotate via .env edit + container restart.
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Mode flag — currently informational; the app derives tier from
# VIBEFORGE_HOSTNAME (-dev. / -uat. / public DNS = PROD).
APP_ENV=production

# ─── Database ────────────────────────────────────────────────────────────────
# Postgres credentials for the bundled `db` service. The DATABASE_URL must
# match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below.
# Generate the password with:  openssl rand -base64 24
POSTGRES_DB=vibeforge
POSTGRES_USER=vibeforge
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg2://vibeforge:changeme@db:5432/vibeforge

# ─── Vaultwarden (optional) ──────────────────────────────────────────────────
# Required ONLY if the vaultwarden service is enabled in docker-compose.yml.
# If you removed the vaultwarden service block, you can leave this commented
# or set to any non-empty value — the app does not read it directly.
# Generate with:  openssl rand -hex 32
# VAULTWARDEN_ADMIN_TOKEN=change-me-only-if-vaultwarden-runs

# ─── First-run notes ─────────────────────────────────────────────────────────
# 1. After `docker compose up -d`, the app has no Super Admin (SA) user.
#    Hit POST /api/v2/bootstrap/create-sa with {email, display_name, password}
#    to create one. Email accepts .local / .test / .example TLDs (VF-252).
#    Password minimum: 12 chars.
# 2. Once SA exists, the bootstrap endpoints become SA-only.
# 3. Browse to https://${VIBEFORGE_HOSTNAME}/admin/login to manage the install.
